# ── Core ──────────────────────────────────────────────────────────────────────
PORT=5050
ADMIN_PORT=5051
FRONTEND_URL=http://localhost:3000

# ── Admin panel credentials (required for admin login) ───────────────────────
# If either is unset, /api/admin/login returns 503.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Supabase (server-side admin client) ──────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Used to sign session JWTs so supabase.from(...) RLS policies see auth.uid().
# Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# ── Google OAuth (for /api/auth/google) ──────────────────────────────────────
# Same Web client ID the frontend uses (REACT_APP_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=

# ── Scraper database (read-only Postgres) ────────────────────────────────────
SCRAPER_DB_URL=

# ── Job source API keys ──────────────────────────────────────────────────────
JSEARCH_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
USAJOBS_API_KEY=
USAJOBS_EMAIL=
