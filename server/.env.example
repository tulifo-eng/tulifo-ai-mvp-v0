# ── Core ──────────────────────────────────────────────────────────────────────
PORT=5050
ADMIN_PORT=5051
FRONTEND_URL=http://localhost:3000

# ── Admin panel credentials (required for admin login) ───────────────────────
# If either is unset, /api/admin/login returns 503.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Supabase (server-side admin client) ──────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Scraper database (read-only Postgres) ────────────────────────────────────
SCRAPER_DB_URL=

# ── Job source API keys ──────────────────────────────────────────────────────
JSEARCH_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
USAJOBS_API_KEY=
USAJOBS_EMAIL=
